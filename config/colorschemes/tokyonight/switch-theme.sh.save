#Apply waybar

truncate -s 0 ~/.config/waybar/config.jsonc
echo '{ "include": ["/home/gwallgof/.config/colorschemes/tokyonight/waybar/config.jsonc"] }' > ~/.config/waybar/config.jsonc
truncate -s 0 ~/.config/waybar/style.css
echo '@import url("file:///home/gwallgof/.config/colorschemes/tokyonight/waybar/style.css");' > ~/.config/waybar/style.css
pkill waybar
waybar &

# Apply rofi

echo '@import "/home/gwallgof/.config/colorschemes/tokyonight/rofi/config.rasi"' > ~/.config/rofi/config.rasi

# Apply Alacritty

echo 'general.import = [ "/home/gwallgof/.config/colorschemes/tokyonight/alacritty/alacritty.toml" ]' > .config/alacritty/alacritty.toml

#Apply Hypr

sed -i '2c\source = ~/.config/colorschemes/tokyonight/hypr/colors/tokyonight.conf' /home/gwallgof/.config/hypr/hyprland.conf

#Apply GTK Theme And Icon Theme

gsettings set org.gnome.desktop.interface gtk-theme "Kripton-v404"
gsettings set org.gnome.desktop.interface icon-theme 'TokyoNight-SE'

#Apply Wallpaper

swaybg -i /home/gwallgof/Pictures/wallpapers/tokyonight/flowering-rain.png -m fill

exit



